# ─────────────────────────────────────────────────────────────────────
# ACH HIM Platform · environment variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` before running `npm run dev` or `next build`.

# Supabase  (required)
# ─────────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Service-role key (required only for seed scripts and admin paths;
# NEVER expose this to the browser).
SUPABASE_SERVICE_ROLE_KEY=ey...

# Google Gemini API  (optional)
# ─────────────────────────────────────────────────────────────────────
# Powers AI-assisted drafting inside the Funding & Bid Evidence Pack
# (model: gemini-1.5-flash, free tier).
# If unset, the rest of the Evidence Pack still works — the AI panel
# simply shows "AI drafting unavailable — Evidence Pack data still
# available for manual drafting."
GEMINI_API_KEY=

# App config  (optional)
# ─────────────────────────────────────────────────────────────────────
# Site URL is used to construct magic-link redirects. Defaults to
# request origin if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
